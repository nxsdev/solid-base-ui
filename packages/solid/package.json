  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json",
    "lint": "oxlint src && bash ../../.ruler/skills/solidjs2-headless-ui/scripts/check-solid2-migration.sh src",
    "lint:fix": "oxlint --fix src && bash ../../.ruler/skills/solidjs2-headless-ui/scripts/check-solid2-migration.sh src",
    "format": "oxfmt --check src",
    "format:write": "oxfmt src",
    "test": "vitest run --config vitest.config.mts"
