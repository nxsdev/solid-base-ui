{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "outputs": ["dist/**", "build/**", ".next/**"]
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "typecheck": {
            "dependsOn": ["^typecheck"],
            "outputs": []
        },
        "lint": {
            "dependsOn": ["^lint"],
            "outputs": []
        },
        "lint:fix": {
            "dependsOn": ["^lint:fix"],
            "outputs": []
        },
        "format": {
            "outputs": []
        },
        "format:write": {
            "outputs": []
        },
        "test": {
            "dependsOn": ["build", "^build"],
            "outputs": ["coverage/**", "test-results/**"]
        }
    }
}
